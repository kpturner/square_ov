generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OVType {
  craft
  ra
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String
  email                String    @unique
  passwordHash         String    @map("password")
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  lastAccessDate       DateTime?
  ovs                  OV[]
}

model OV {
  id                   Int       @id @default(autoincrement())
  name                 String
  ovDate               DateTime
  ovType               OVType    @default(craft)
  createdAt            DateTime  @default(now())
  userId               Int
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  officers             Officer[]
  alignWardens         Boolean   @default(true)
  activeDCsFront       Boolean   @default(true)
  activeDepsFront      Boolean   @default(false)
  includeGrandOfficers Boolean   @default(false)
  reverseStewardOrder  Boolean   @default(false)
  carpetCapacity       Int       @default(15)
  splitByRow           Boolean   @default(false)

  @@unique([userId, name, ovType])
  @@index([userId], map: "OV_userId_fkey")
}

model Officer {
  id                    Int      @id @default(autoincrement())
  name                  String
  email                 String?
  phone                 String?
  rank                  String?
  rankOverride          String?
  provOfficerYear       Int?
  grandOfficer          Boolean
  grandOfficerYear      Int?
  active                Boolean
  ovId                  Int
  position              String
  grandActive           Boolean?
  grandRank             String?
  original              Boolean?
  attending             Boolean?
  excludeFromProcession Boolean?
  ov                    OV       @relation(fields: [ovId], references: [id], onDelete: Cascade)

  @@index([ovId], map: "Officer_ovId_fkey")
}

enum Position {
  automatic
  head_of_south
  head_of_north
  sword_bearer
  standard_bearer
  vip
}

model ActiveOfficer {
  id               Int     @id @default(autoincrement())
  ovType           OVType  @default(craft)
  year             String
  number           Int
  provincialRank   String
  givenName        String
  familyName       String
  familiarName     String?
  postNominals     String?
  primaryEmail     String?
  preferredPhoneNo String?

  // Reverse relations (optional, but handy if you want to query back)
  oVMastersAsSword    OVMaster[] @relation("SwordRelation")
  oVMastersAsStandard OVMaster[] @relation("StandardRelation")
  oVMastersAsSteward  OVMaster[] @relation("StewardRelation")
  oVMastersAsOfficer1 OVMaster[] @relation("Officer1Relation")
  oVMastersAsOfficer2 OVMaster[] @relation("Officer2Relation")
  oVMastersAsOfficer3 OVMaster[] @relation("Officer3Relation")
  oVMastersAsOfficer4 OVMaster[] @relation("Officer4Relation")
  oVMastersAsOfficer5 OVMaster[] @relation("Officer5Relation")
  oVMastersAsOfficer6 OVMaster[] @relation("Officer6Relation")
  oVMastersAsOfficer7 OVMaster[] @relation("Officer7Relation")

  @@unique([ovType, year, number], name: "type_year_number")
  @@unique([ovType, year, primaryEmail], name: "type_year_email")
}

model OVMaster {
  id          Int      @id @default(autoincrement())
  ovType      OVType   @default(craft)
  year        String
  number      Int
  date        DateTime
  lodgeName   String
  lodgeNumber String
  location    String
  vip         String
  dc          String
  sword       Int?
  standard    Int?
  steward     Int?
  officer1    Int?
  officer2    Int?
  officer3    Int?
  officer4    Int?
  officer5    Int?
  officer6    Int?
  officer7    Int?

  // Composite foreign key relations to (year, number) in ActiveOfficer
  swordOfficer    ActiveOfficer? @relation("SwordRelation", fields: [ovType, year, sword], references: [ovType, year, number])
  standardOfficer ActiveOfficer? @relation("StandardRelation", fields: [ovType, year, standard], references: [ovType, year, number])
  stewardOfficer  ActiveOfficer? @relation("StewardRelation", fields: [ovType, year, steward], references: [ovType, year, number])
  officer1Officer ActiveOfficer? @relation("Officer1Relation", fields: [ovType, year, officer1], references: [ovType, year, number])
  officer2Officer ActiveOfficer? @relation("Officer2Relation", fields: [ovType, year, officer2], references: [ovType, year, number])
  officer3Officer ActiveOfficer? @relation("Officer3Relation", fields: [ovType, year, officer3], references: [ovType, year, number])
  officer4Officer ActiveOfficer? @relation("Officer4Relation", fields: [ovType, year, officer4], references: [ovType, year, number])
  officer5Officer ActiveOfficer? @relation("Officer5Relation", fields: [ovType, year, officer5], references: [ovType, year, number])
  officer6Officer ActiveOfficer? @relation("Officer6Relation", fields: [ovType, year, officer6], references: [ovType, year, number])
  officer7Officer ActiveOfficer? @relation("Officer7Relation", fields: [ovType, year, officer7], references: [ovType, year, number])

  @@unique([ovType, year, number], name: "type_year_number")
}

model VIP {
  id             Int     @id @default(autoincrement())
  ovType         OVType  @default(craft)
  year           String
  provincialRank String
  name           String
  address        String?
  email          String?
  phone          String?
  mobile         String?

  @@unique([ovType, year, name], name: "type_year_name")
}
